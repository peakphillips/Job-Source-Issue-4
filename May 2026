}

function renderCard(j) {
  var hasSal = j.salary && j.salary !== "Competitive";
  return '<a class="job-card" href="' + j.link + '" target="_blank" rel="noopener">' +
    '<div class="card-top"><div class="job-title">' + j.title + '</div>' +
    '<div class="apply-arrow">' + arrIcon() + '</div></div>' +
    '<div class="job-company">' + j.company + '</div>' +
    '<div class="card-tags">' +
      '<span class="tag">' + locIcon() + ' ' + j.location + '</span>' +
      (hasSal
        ? '<span class="tag salary-tag">' + dolIcon() + ' ' + j.salary + '</span>'
        : '<span class="tag">' + dolIcon() + ' Competitive</span>') +
    '</div></a>';
}

function render() {
  var filtered = getFiltered();
  var mc = document.getElementById("mainContent");
  var nr = document.getElementById("noResults");
  var rc = document.getElementById("resultCount");

  rc.innerHTML = "<strong>" + filtered.length + "</strong> role" + (filtered.length !== 1 ? "s" : "");

  if (!filtered.length) {
    mc.innerHTML = "";
    nr.style.display = "block";
    return;
  }
  nr.style.display = "none";

  var order = [];
  JOBS.forEach(function(j) { if (!order.includes(j.sector)) order.push(j.sector); });

  var by = {};
  order.forEach(function(s) { by[s] = []; });
  filtered.forEach(function(j) { by[j.sector].push(j); });

  var html = "";
  order.forEach(function(s) {
    var jobs = by[s];
    if (!jobs.length) return;
    html += '<div class="sector-section">' +
      '<div class="sector-heading">' +
        '<div class="sector-dot"></div>' +
        '<div class="sector-title">' + s + '</div>' +
        '<div class="sector-line"></div>' +
        '<div class="sector-count">' + jobs.length + ' role' + (jobs.length !== 1 ? 's' : '') + '</div>' +
      '</div>' +
      '<div class="jobs-grid">' + jobs.map(renderCard).join("") + '</div>' +
    '</div>';
  });
  mc.innerHTML = html;

  var cards = mc.querySelectorAll(".job-card");
  cards.forEach(function(c, i) {
    c.style.opacity = "0";
    c.style.transform = "translateY(8px)";
    c.style.transition = "opacity 0.22s ease, transform 0.22s ease, box-shadow 0.2s, border-color 0.2s";
    setTimeout(function() {
      c.style.opacity = "1";
      c.style.transform = "translateY(0)";
    }, 10 + i * 8);
  });
}

document.addEventListener("DOMContentLoaded", function() {
  document.querySelectorAll(".filter-btn").forEach(function(btn) {
    btn.addEventListener("click", function() {
      document.querySelectorAll(".filter-btn").forEach(function(b) { b.classList.remove("active"); });
      btn.classList.add("active");
      activeSector = btn.dataset.sector;
      render();
    });
  });

  var debounce;
  document.getElementById("searchInput").addEventListener("input", function(e) {
    clearTimeout(debounce);
    debounce = setTimeout(function() {
      searchTerm = e.target.value;
      render();
    }, 200);
  });

  render();
});
</script>
</body>
</html>
